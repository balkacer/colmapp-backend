MONGO_URI=mongodb+srv://<username>:<password>@<cluster-address>
MONGO_DBNAME=colmapp-notifications
RABBITMQ_URI=localhost:5672
RABBITMQ_NOTIFICATIONS_QUEUE=notifications_queue
SERVICE_NAME=notifications-service
SERVICE_SECRET=my_super_secret_key
# Other environment variables can be added here as needed
RABBITMQ_AUTH_QUEUE=auth_queue